# Copy to .env and adjust for your environment.

# App
APP_NAME="PeakForm"
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

# Security (CHANGE THIS in production: `openssl rand -hex 32`)
SECRET_KEY=dev-secret-change-me-please-0123456789abcdef
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database
# Dev default is local SQLite. For production use Postgres, e.g.:
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/peakform
DATABASE_URL=sqlite:///./peakform.db

# Storage (local filesystem for now; swap to S3 later)
STORAGE_DIR=./storage

# CORS (comma-separated origins for the frontend)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# AI coaching — get your key at https://console.anthropic.com/
# Leave blank to disable AI coaching (all other features still work).
ANTHROPIC_API_KEY=

# Analysis tuning
POSE_MIN_DETECTION_CONFIDENCE=0.5
POSE_MIN_TRACKING_CONFIDENCE=0.5
MAX_ANALYSIS_FRAMES=900
# Default bowler height in metres (calibrates estimated release speed).
ATHLETE_HEIGHT_M=1.75
